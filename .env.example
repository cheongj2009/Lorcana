# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Never commit real credentials.

# --- ntfy.sh push notifications (recommended, no credentials) ---------------
# Subscribe to THIS exact topic in the ntfy app to get alerts on your phone.
# Pick a private, hard-to-guess value (anyone who knows it can read/post).
NTFY_TOPIC=lorcana-watch-CHANGEME-random123
NTFY_SERVER=https://ntfy.sh
# Optional bearer token for protected/self-hosted ntfy servers.
# NTFY_TOKEN=

# --- macOS desktop notification (no setup needed) ---------------------------
ENABLE_DESKTOP_NOTIFICATION=true

# --- Email via SMTP (optional) ----------------------------------------------
# Gmail requires an "App Password" (2FA must be enabled):
#   https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password-here
# ALERT_TO=you@example.com
# ALERT_FROM=you@example.com
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
